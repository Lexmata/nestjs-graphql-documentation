{
  "name": "@lexmata/nestjs-graphql-documentation",
  "version": "0.2.0",
  "description": "Swagger-like documentation module for NestJS GraphQL applications.",
  "keywords": [
    "nestjs",
    "graphql",
    "documentation",
    "swagger",
    "docs",
    "mercurius",
    "apollo"
  ],
  "license": "MIT",
  "author": "Lexmata LLC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lexmata/nestjs-graphql-documentation.git"
  },
  "bugs": {
    "url": "https://github.com/Lexmata/nestjs-graphql-documentation/issues"
  },
  "homepage": "https://github.com/Lexmata/nestjs-graphql-documentation#readme",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/cjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "prepare": "husky",
    "build": "pnpm run build:cjs && pnpm run build:esm && pnpm run build:flag-modules",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:flag-modules": "node scripts/flag-dual-modules.mjs",
    "build:clean": "rm -rf dist",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:all": "pnpm test && pnpm test:e2e",
    "test:cov": "vitest run --coverage",
    "commitlint": "commitlint --edit",
    "release:preflight": "pnpm run lint && pnpm run format:check && pnpm exec tsc --noEmit && pnpm run build && pnpm run test:cov",
    "release:pack": "pnpm pack --pack-destination ./dist-pack",
    "release:dry": "pnpm publish --dry-run --no-git-checks",
    "prepublishOnly": "pnpm run build:clean && pnpm run release:preflight"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,mjs,cjs}": [
      "prettier --write"
    ]
  },
  "peerDependencies": {
    "@nestjs/cache-manager": "^3.0.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@nestjs/graphql": "^12.0.0 || ^13.0.0",
    "cache-manager": ">=6",
    "graphql": "^16.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/cache-manager": {
      "optional": true
    },
    "cache-manager": {
      "optional": true
    }
  },
  "devDependencies": {
    "@apollo/server": "^5.5.0",
    "@as-integrations/express5": "^1.1.2",
    "@as-integrations/fastify": "^3.1.0",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@nestjs/apollo": "^13.3.0",
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/graphql": "^13.3.0",
    "@nestjs/mercurius": "^13.3.0",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/platform-fastify": "^11.1.19",
    "@nestjs/testing": "^11.1.19",
    "@swc/core": "^1.15.32",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "cache-manager": "^7.2.8",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unicorn": "^64.0.0",
    "graphql": "^16.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "mercurius": "^16.9.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.5"
  }
}
